{
  "name": "runedex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"if(!process.env.SKIP_PREBUILD){require('child_process').execSync('node src/scripts/generate-manifest.mjs && node src/scripts/validate-integrity.mjs',{stdio:'inherit'})}\"",
    "prebuild": "node src/scripts/generate-manifest.mjs && node src/scripts/validate-integrity.mjs",
    "dev": "rm -f .next/dev/lock && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "validate": "node src/scripts/validate-integrity.mjs",
    "stats": "node src/scripts/generate-health-report.mjs",
    "update-data": "node src/scripts/update-ddragon.mjs"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@use-gesture/react": "^10.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.555.0",
    "next": "^16.0.7",
    "next-intl": "^4.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-leaflet": "^5.0.0",
    "react-redux": "^9.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/axios": "^0.9.36",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-redux": "^7.1.34",
    "@vitalets/google-translate-api": "^9.2.1",
    "baseline-browser-mapping": "^2.9.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}